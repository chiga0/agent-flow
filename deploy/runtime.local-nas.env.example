# Local workstation/NAS profile.
# Prefer this for the V2 control plane when the public VPS is only 2C2G.

RUN_MANAGER_TOKEN=replace-with-random-token
RUN_MANAGER_BOOTSTRAP_EMAIL=owner@example.com
RUNTIME_BOOTSTRAP_PASSWORD=replace-with-random-password
RUN_MANAGER_BOOTSTRAP_NAME=Owner
RUN_MANAGER_SESSION_SECRET=replace-with-random-session-secret

# Safe default: only this machine can reach the runtime. For trusted LAN/NAS
# access, change to 0.0.0.0 and protect port 8765 with a firewall or VPN.
RUNTIME_BIND=127.0.0.1
RUNTIME_UID=1000
RUNTIME_GID=1000

RUN_MANAGER_WORKER_CAPACITY=0
RUN_MANAGER_LEASE_TTL_SECONDS=60
RUN_MANAGER_DEFAULT_CPUS=1.0
RUN_MANAGER_MAX_CPUS=2.0
RUN_MANAGER_DEFAULT_MEMORY_MB=1024
RUN_MANAGER_MAX_MEMORY_MB=2048
RUN_MANAGER_DEFAULT_PIDS=512
RUN_MANAGER_MAX_PIDS=1024
RUN_MANAGER_DEFAULT_TIMEOUT_SECONDS=3600
RUN_MANAGER_MAX_TIMEOUT_SECONDS=7200

RUN_MANAGER_CLEANUP_ENABLED=1
RUN_MANAGER_WORKSPACE_RETENTION_SECONDS=604800
RUN_MANAGER_ARTIFACT_RETENTION_SECONDS=2592000
RUN_MANAGER_CLEANUP_INTERVAL_SECONDS=3600

RUNTIME_CPUS=1.5
RUNTIME_MEMORY_LIMIT=1536m
RUNTIME_PIDS_LIMIT=1024

# Optional registry/package overrides for restricted or slow Docker Hub networks.
NODE_IMAGE=node:22-slim
PYTHON_IMAGE=python:3.13-slim
QWEN_NODE_PACKAGE=@qwen-code/qwen-code@0.19.3
CODEX_NODE_PACKAGE=@openai/codex@0.144.5
OPENCODE_NODE_PACKAGE=opencode-ai@1.18.3

V2_DEPLOYMENT_PROFILE=local-nas
V2_ENABLE_REAL_CLI_ADAPTERS=0
V2_QWEN_CODE_COMMAND=qwen
V2_CODEX_CLI_COMMAND=codex exec --skip-git-repo-check -
V2_CLAUDE_CODE_COMMAND=claude -p
V2_OPENCODE_COMMAND=opencode run
V2_LOCAL_EXECUTION_UNIT_ID=local-runtime
V2_LOCAL_EXECUTION_UNIT_KIND=co-located-runtime
V2_LOCAL_EXECUTION_UNIT_LABELS_JSON={"region":"local","tier":"personal"}
V2_LOCAL_EXECUTION_UNIT_RESOURCES_JSON={"cpu":2,"memory_mb":2048}
V2_LOCAL_EXECUTION_UNIT_ADAPTERS=fake,qwen,codex,opencode
V2_LOCAL_EXECUTION_UNIT_FEATURES=workspace,artifacts,events,cli-adapters

# Required only when V2_ENABLE_REAL_CLI_ADAPTERS=1 and the selected CLI needs it.
OPENAI_API_KEY=

QWEN_EXECUTOR_STRATEGY=shared
QWEN_CONTAINER_CPUS=1
QWEN_CONTAINER_MEMORY_MB=1024
QWEN_CONTAINER_PIDS=512

# Use a host path for durable state on a NAS/workstation.
# RUNTIME_ARTIFACTS_DIR=/srv/agentflow/artifacts

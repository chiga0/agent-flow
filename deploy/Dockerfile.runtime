ARG NODE_BASE_IMAGE=node:22-slim
ARG PYTHON_BASE_IMAGE=python:3.13-slim

FROM ${NODE_BASE_IMAGE} AS node-runtime

FROM ${PYTHON_BASE_IMAGE}

ARG QWEN_NODE_PACKAGE=@qwen-code/qwen-code@0.19.3
ARG CODEX_NODE_PACKAGE=@openai/codex@0.144.5
ARG OPENCODE_NODE_PACKAGE=opencode-ai@1.18.3

WORKDIR /app

COPY runtime/requirements.txt /app/runtime/requirements.txt

COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 update \
    && apt-get install -y --no-install-recommends ca-certificates git \
    && ln -s ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -s ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && node --version \
    && npm install -g "${QWEN_NODE_PACKAGE}" "${CODEX_NODE_PACKAGE}" "${OPENCODE_NODE_PACKAGE}" \
    && python3 -m pip install --no-cache-dir -r /app/runtime/requirements.txt \
    && rm -rf /var/lib/apt/lists/* /root/.npm

RUN useradd --create-home --shell /usr/sbin/nologin runtime

COPY runtime /app/runtime
COPY scripts /app/scripts

RUN mkdir -p /data/artifacts && chown -R runtime:runtime /data/artifacts /app

USER runtime

EXPOSE 8765

CMD ["python3", "-m", "runtime.cloud_agents_runtime", "--host", "0.0.0.0", "--port", "8765", "--artifact-root", "/data/artifacts", "--protect-health"]
